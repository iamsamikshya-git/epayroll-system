@model E_PayRoll.Models.Teacher
@{
    ViewBag.Title = "Teacher Profile";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";

    string photoSrc = Model.Photo != null && Model.Photo.Length > 0
        ? $"data:image/jpeg;base64,{Convert.ToBase64String(Model.Photo)}"
        : Url.Content("~/images/placeholder-user.png"); // put a placeholder here
}

@section Styles {
    <style>
        .profile-card { background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:22px; }
        .profile-header { display:flex; align-items:center; gap:20px; }
        .profile-header img { width:140px; height:140px; object-fit:cover; border-radius:50%; border:3px solid #eee; }
        .muted { color:#6b7280; }
        .section-title { font-weight:700; font-size:1.05rem; margin:.5rem 0 1rem 0; color:#334155; }
        .grid-2 { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px; }
        .grid-3 { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:12px; }
        .field { background:#fafafa; border:1px solid #eee; border-radius:10px; padding:10px 12px; }
        .label { font-size:.82rem; color:#6b7280; margin-bottom:2px; }
        .value { font-weight:600; word-break:break-word; }
        @@media (max-width: 992px){ .grid-3 { grid-template-columns: repeat(2,1fr);} }
        @@media (max-width: 768px){ .grid-2, .grid-3 { grid-template-columns: 1fr; } }
    </style>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="m-0">Teacher Profile</h3>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit","School", new { id = Model.Id })" class="btn btn-primary">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">Back</a>
            <button class="btn btn-outline-secondary" onclick="window.print()"><i class="fa-solid fa-print"></i> Print</button>
        </div>
    </div>

    <div class="profile-card">
        <!-- Header -->
        <div class="profile-header mb-4">
            <img src="@photoSrc" alt="Teacher Photo" />
            <div>
                <h4 class="mb-1">@($"{Model.FirstName} {Model.MiddleName} {Model.LastName}".Trim())</h4>
                <div class="muted">ID: @Model.Id</div>
                <div class="muted">School: @Model.SchoolName (@Model.SchoolCode)</div>
                <div class="muted">Type: @Model.Type</div>
            </div>
        </div>

        <!-- Personal Info -->
        <div class="section-title">Personal Information</div>
        <div class="grid-3 mb-3">
            <div class="field"><div class="label">Gender</div><div class="value">@Model.Gender</div></div>
            <div class="field"><div class="label">Date of Birth</div><div class="value">@Model.DateOfBirth.ToString("yyyy-MM-dd")</div></div>
            <div class="field"><div class="label">Contact</div><div class="value">@Model.Contact</div></div>
            <div class="field"><div class="label">Email</div><div class="value">@Model.Email</div></div>
            <div class="field"><div class="label">Ethnicity</div><div class="value">@Model.Ethnicity</div></div>
            <div class="field"><div class="label">Mother Tongue</div><div class="value">@Model.MotherTongue</div></div>
            <div class="field"><div class="label">Disability</div><div class="value">@Model.Disability</div></div>
            <div class="field"><div class="label">Father's Name</div><div class="value">@Model.FatherName</div></div>
            <div class="field"><div class="label">Mother's Name</div><div class="value">@Model.MotherName</div></div>
            <div class="field"><div class="label">Spouse Name</div><div class="value">@Model.SpouseName</div></div>
        </div>

        <!-- Permanent Address -->
        <div class="section-title">Permanent Address</div>
        <div class="grid-3 mb-3">
            <div class="field"><div class="label">Country</div><div class="value">@Model.PermanentCountry</div></div>
            <div class="field"><div class="label">Province</div><div class="value">@Model.PermanentProvince</div></div>
            <div class="field"><div class="label">District</div><div class="value">@Model.PermanentDistrict</div></div>
            <div class="field"><div class="label">Local Level</div><div class="value">@Model.PermanentLocalLevel</div></div>
            <div class="field"><div class="label">Ward</div><div class="value">@Model.PermanentWard</div></div>
            <div class="field"><div class="label">Tole</div><div class="value">@Model.PermanentTole</div></div>
        </div>

        <!-- Temporary Address -->
        <div class="section-title">Temporary Address</div>
        <div class="grid-3 mb-3">
            <div class="field"><div class="label">Country</div><div class="value">@Model.TemporaryCountry</div></div>
            <div class="field"><div class="label">Province</div><div class="value">@Model.TemporaryProvince</div></div>
            <div class="field"><div class="label">District</div><div class="value">@Model.TemporaryDistrict</div></div>
            <div class="field"><div class="label">Local Level</div><div class="value">@Model.TemporaryLocalLevel</div></div>
            <div class="field"><div class="label">Ward</div><div class="value">@Model.TemporaryWard</div></div>
            <div class="field"><div class="label">Tole</div><div class="value">@Model.TemporaryTole</div></div>
        </div>

        <!-- Documents -->
        <div class="section-title">Document Information</div>
        <div class="grid-3 mb-3">
            <div class="field"><div class="label">Citizenship No.</div><div class="value">@Model.CitizenshipNo</div></div>
            <div class="field"><div class="label">Citizenship Issue Date</div><div class="value">@Model.CitizenshipIssueDate?.ToString("yyyy-MM-dd")</div></div>
            <div class="field"><div class="label">Citizenship Issue District</div><div class="value">@Model.CitizenshipIssueDistrict</div></div>
            <div class="field"><div class="label">National ID</div><div class="value">@Model.NationalId</div></div>
            <div class="field"><div class="label">Permanent Account No.</div><div class="value">@Model.PermanentAccount</div></div>
            <div class="field"><div class="label">Employee Union Fund No.</div><div class="value">@Model.UnionFundNo</div></div>
            <div class="field"><div class="label">Citizen Investment Fund No.</div><div class="value">@Model.InvestmentFundNo</div></div>
            <div class="field"><div class="label">Bank Name</div><div class="value">@Model.BankName</div></div>
            <div class="field"><div class="label">Bank Account No.</div><div class="value">@Model.BankAccount</div></div>
            <div class="field"><div class="label">Teaching License No.</div><div class="value">@Model.LicenseNo</div></div>
            <div class="field"><div class="label">Highest Contribution-Based Grant Fund</div><div class="value">@Model.ContributionFund</div></div>
            <div class="field"><div class="label">Sheet Roll</div><div class="value">@Model.SheetRoll</div></div>
        </div>

        <!-- Appointment Details -->
        <div class="section-title">Appointment Details</div>
        <div class="grid-3 mb-3">
            <div class="field"><div class="label">Teacher Level</div><div class="value">@Model.TeacherLevel</div></div>
            <div class="field"><div class="label">Teacher Category</div><div class="value">@Model.TeacherCategory</div></div>
            <div class="field"><div class="label">Appointment Type</div><div class="value">@Model.AppointmentType</div></div>
            <div class="field"><div class="label">Appointment Status</div><div class="value">@Model.AppointmentStatus</div></div>
            <div class="field"><div class="label">Teacher Status</div><div class="value">@Model.TeacherStatus</div></div>
        </div>

        <!-- Qualification -->
        <div class="section-title">Qualification</div>
        <div class="grid-3 mb-3">
            <div class="field"><div class="label">Education Level</div><div class="value">@Model.EducationLevel</div></div>
            <div class="field"><div class="label">Board / University</div><div class="value">@Model.BoardUniversity</div></div>
            <div class="field"><div class="label">Passed Year</div><div class="value">@Model.PassedYear</div></div>
            <div class="field"><div class="label">Faculty</div><div class="value">@Model.Faculty</div></div>
            <div class="field"><div class="label">Grade / GPA</div><div class="value">@Model.GradeGPA</div></div>
        </div>

        <!-- Experience -->
        <div class="section-title">Experience</div>
        <div class="grid-3">
            <div class="field"><div class="label">Post Type</div><div class="value">@Model.PostType</div></div>
            <div class="field"><div class="label">Appointment Start Date</div><div class="value">@Model.AppointmentStartDate.ToString("yyyy-MM-dd")</div></div>
            <div class="field"><div class="label">Decision Date</div><div class="value">@Model.DecisionDate.ToString("yyyy-MM-dd")</div></div>
            <div class="field"><div class="label">Attendance Date</div><div class="value">@Model.AttendanceDate.ToString("yyyy-MM-dd")</div></div>
            <div class="field"><div class="label">Appointed School</div><div class="value">@Model.AppointedSchool</div></div>
            <div class="field"><div class="label">School Address</div><div class="value">@Model.SchoolAddress</div></div>
            <div class="field"><div class="label">Appointed Subject</div><div class="value">@Model.AppointedSubject</div></div>
        </div>
    </div>
</div>
