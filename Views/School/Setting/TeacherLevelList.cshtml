@model IEnumerable<E_PayRoll.Models.TeacherLevel>

@{
    ViewBag.Title = "Teacher Level List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

@section Styles {
    <style>
        .table-wrapper {
            margin-top: 40px;
            margin-left: 30px;
            margin-right: 20px;
        }

        .action-btns {
            display: inline-flex; /* keep buttons on one line */
            gap: 6px;
            align-items: center;
        }
        .action-btns form { display: inline; margin: 0; }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap; /* avoid clipping on small screens */
            gap: 8px;
        }

        .header-row h4 {
            margin: 0;
            text-align: center;
            width: 100%;
        }

        .table th, .table td {
            vertical-align: middle !important;
        }
    </style>
}

<div class="container table-wrapper">
    <div class="header-row mb-3">
        <h4>Teacher Level List</h4>
        <a href="@Url.Action("AddTeacherLevel", "School")" class="btn btn-success">
            <i class="fas fa-plus"></i> Add New Level
        </a>
    </div>

    <!-- Controls: page length + search (no external libs) -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            Show
            <select id="pageLength" class="form-control d-inline-block" style="width:auto;">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            entries
        </div>
        <div>
            Search:
            <input type="text" id="searchBox" class="form-control d-inline-block" style="width:220px;" />
        </div>
    </div>

    <table id="teacherLevelTable" class="table table-bordered table-striped" style="width:100%;">
        <thead class="thead-dark">
            <tr>
                <th>S.N</th>
                <th>Level Name</th>
                <th>Level Code</th>
                <th style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                var index = 1;
                foreach (var level in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td>@level.Name</td>
                        <td>@level.Code</td>
                        <td>
                            <div class="action-btns">
                                <a href="@Url.Action("EditTeacherLevel", "School", new { id = level.Id })"
                                   class="btn btn-sm btn-primary" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>

                                <form asp-action="DeleteTeacherLevel"
                                      asp-controller="School"
                                      asp-route-id="@level.Id"
                                      method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this level?');">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    index++;
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">No records found.</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination strip -->
    <div class="d-flex justify-content-between align-items-center">
        <div id="tableInfo" class="text-muted"></div>
        <div>
            <button id="prevPage" class="btn btn-sm btn-secondary">Previous</button>
            <button id="nextPage" class="btn btn-sm btn-secondary">Next</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const table = document.getElementById("teacherLevelTable");
            const allRows = Array.from(table.querySelectorAll("tbody tr"));
            const searchBox = document.getElementById("searchBox");
            const pageLengthSelect = document.getElementById("pageLength");
            const prevBtn = document.getElementById("prevPage");
            const nextBtn = document.getElementById("nextPage");
            const info = document.getElementById("tableInfo");

            let currentPage = 1;
            let pageLength = parseInt(pageLengthSelect.value, 10);

            function getFilteredRows() {
                const q = searchBox.value.trim().toLowerCase();
                if (!q) return allRows;
                return allRows.filter(r => r.innerText.toLowerCase().includes(q));
            }

            function render() {
                const filtered = getFilteredRows();
                const total = filtered.length;
                const totalPages = Math.max(1, Math.ceil(total / pageLength));
                currentPage = Math.min(currentPage, totalPages);

                // hide all
                allRows.forEach(r => r.style.display = "none");

                // show current page
                const start = (currentPage - 1) * pageLength;
                const end = start + pageLength;
                filtered.slice(start, end).forEach(r => r.style.display = "");

                // update info
                const showFrom = total === 0 ? 0 : start + 1;
                const showTo = Math.min(end, total);
                info.textContent = `Showing ${showFrom} to ${showTo} of ${total} entries`;

                // toggle buttons
                prevBtn.disabled = currentPage <= 1;
                nextBtn.disabled = currentPage >= totalPages;
            }

            // events
            searchBox.addEventListener("input", () => { currentPage = 1; render(); });
            pageLengthSelect.addEventListener("change", () => {
                pageLength = parseInt(pageLengthSelect.value, 10);
                currentPage = 1;
                render();
            });
            prevBtn.addEventListener("click", () => {
                if (currentPage > 1) { currentPage--; render(); }
            });
            nextBtn.addEventListener("click", () => {
                const totalPages = Math.max(1, Math.ceil(getFilteredRows().length / pageLength));
                if (currentPage < totalPages) { currentPage++; render(); }
            });

            // initial paint
            render();
        });
    </script>
}
