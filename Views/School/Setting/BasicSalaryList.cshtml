@model List<E_PayRoll.Models.BasicSalary>

@{
    ViewBag.Title = "Basic Salary List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

@section Styles {
    <style>
        .table-wrapper {
            margin-top: 40px;
            margin-left: 100px;
            margin-right: 20px;
        }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        .header-row h3 {
            margin: 0 auto;
            text-align: center;
            flex-grow: 1;
        }

        .action-btns {
            display: inline-flex;  /* keep buttons inline */
            gap: 6px;
            align-items: center;
        }
        .action-btns form { display:inline; margin:0; }

        .table th, .table td {
            vertical-align: middle !important;
        }
    </style>
}

<div class="container table-wrapper">
    <div class="header-row mb-3">
        <h3>Basic Salary List</h3>
        <a href="@Url.Action("AddBasicSalary", "School")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Base Salary
        </a>
    </div>

    <!-- Controls -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            Show
            <select id="pageLength" class="form-control d-inline-block" style="width:auto;">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            entries
        </div>
        <div>
            Search:
            <input type="text" id="searchBox" class="form-control d-inline-block" style="width:220px;" />
        </div>
    </div>

    <table id="basicSalaryTable" class="table table-bordered table-striped" style="width:100%;">
        <thead class="thead-dark">
            <tr>
                <th>S.N</th>
                <th>Teacher Level</th>
                <th>Teacher Category</th>
                <th>Base Salary Amount</th>
                <th style="width: 160px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                var index = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td>@(item.TeacherLevel?.Name ?? "N/A")</td>
                        <td>@(item.TeacherCategory?.Name ?? "N/A")</td>
                        <td>Rs. @item.BaseSalaryAmount.ToString("N2")</td>
                        <td>
                            <div class="action-btns">
                                <a href="@Url.Action("EditBasicSalary", "School", new { id = item.Id })"
                                   class="btn btn-sm btn-warning" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="DeleteBasicSalary"
                                      asp-controller="School"
                                      method="post"
                                      onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    index++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No salary records found.</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center">
        <div id="tableInfo" class="text-muted"></div>
        <div>
            <button id="prevPage" class="btn btn-sm btn-secondary">Previous</button>
            <button id="nextPage" class="btn btn-sm btn-secondary">Next</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const table = document.getElementById("basicSalaryTable");
            const allRows = Array.from(table.querySelectorAll("tbody tr"));
            const searchBox = document.getElementById("searchBox");
            const pageLengthSelect = document.getElementById("pageLength");
            const prevBtn = document.getElementById("prevPage");
            const nextBtn = document.getElementById("nextPage");
            const info = document.getElementById("tableInfo");

            let currentPage = 1;
            let pageLength = parseInt(pageLengthSelect.value, 10);

            function getFilteredRows() {
                const q = searchBox.value.trim().toLowerCase();
                if (!q) return allRows;
                return allRows.filter(r => r.innerText.toLowerCase().includes(q));
            }

            function render() {
                const filtered = getFilteredRows();
                const total = filtered.length;
                const totalPages = Math.max(1, Math.ceil(total / pageLength));
                currentPage = Math.min(currentPage, totalPages);

                allRows.forEach(r => r.style.display = "none");

                const start = (currentPage - 1) * pageLength;
                const end = start + pageLength;
                filtered.slice(start, end).forEach(r => r.style.display = "");

                const showFrom = total === 0 ? 0 : start + 1;
                const showTo = Math.min(end, total);
                info.textContent = `Showing ${showFrom} to ${showTo} of ${total} entries`;

                prevBtn.disabled = currentPage <= 1;
                nextBtn.disabled = currentPage >= totalPages;
            }

            searchBox.addEventListener("input", () => { currentPage = 1; render(); });
            pageLengthSelect.addEventListener("change", () => {
                pageLength = parseInt(pageLengthSelect.value, 10);
                currentPage = 1;
                render();
            });
            prevBtn.addEventListener("click", () => {
                if (currentPage > 1) { currentPage--; render(); }
            });
            nextBtn.addEventListener("click", () => {
                const totalPages = Math.max(1, Math.ceil(getFilteredRows().length / pageLength));
                if (currentPage < totalPages) { currentPage++; render(); }
            });

            render();
        });
    </script>
}
