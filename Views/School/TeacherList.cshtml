@model IEnumerable<E_PayRoll.Models.Teacher>

@{
    ViewBag.Title = "Teacher List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<h2>Teacher List</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3 text-end">
    <a href="@Url.Action("AddTeacher", "School")" class="btn btn-primary">
        <i class="fa fa-plus"></i> Create Teacher
    </a>
</div>

<div class="row">
    <div class="col-md-10 offset-md-2 col-lg-9 offset-lg-3">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>S.N.</th>
                    <th>Full Name</th>
                    <th>Gender</th>
                    <th>Department</th>
                    <th>Date of Joining</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int sn = 1;
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@sn</td>
                            <td>@($"{item.FirstName ?? ""} {item.MiddleName ?? ""} {item.LastName ?? ""}".Trim())</td>
                            <td>@(item.Gender ?? "-")</td>
                            <td>@(item.Department ?? "-")</td>
                            <td>
                                @(item.DateOfJoining != null 
                                    ? item.DateOfJoining.Value.ToString("yyyy-MM-dd") 
                                    : "-")
                            </td>
                            <td>
                                <a href="@Url.Action("EditTeacher", "School", new { id = item.Id })"
                                   class="btn btn-sm btn-warning"
                                   title="Edit"
                                   onclick="return confirmUpdate(event);">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <a href="@Url.Action("DeleteTeacher", "School", new { id = item.Id })"
                                   class="btn btn-sm btn-danger"
                                   title="Delete"
                                   onclick="return confirmDelete(event);">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        sn++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">No teachers found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(e) {
            if (!confirm('Are you sure you want to delete this teacher?')) {
                e.preventDefault();
                return false;
            }
            return true;
        }
        function confirmUpdate(e) {
            if (!confirm('Are you sure you want to update this teacher information?')) {
                e.preventDefault();
                return false;
            }
            return true;
        }
    </script>
}