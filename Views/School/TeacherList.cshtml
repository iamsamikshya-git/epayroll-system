@model IEnumerable<E_PayRoll.Models.Teacher>
@{
    ViewBag.Title = "Teacher List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
    int sn = 1;
}

<style>
    .main-content {
        margin-left: 250px; /* Adjust this value to match your sidebar width */
        padding: 20px;
    }
</style>

<div class="main-content">
    <h2>Teacher List</h2>

    <!-- Add Teacher Button -->
    <a href="@Url.Action("AddTeacher", "School")" class="btn btn-success mb-3">
        <i class="fa fa-plus"></i> Add Teacher
    </a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" id="successPopup">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>S.N.</th>
                <th>Full Name</th>
                <th>Gender</th>
                <th>Department</th>
                <th>Designation</th>
                <th>Date of Joining</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var teacher in Model)
        {
            <tr>
                <td>@sn</td>
                <td>@($"{teacher.FirstName} {(string.IsNullOrWhiteSpace(teacher.MiddleName) ? "" : teacher.MiddleName + " ")}{teacher.LastName}")</td>
                <td>@teacher.Gender</td>
                <td>@teacher.Department</td>
                <td>@teacher.Designation</td>
                <td>@teacher.DateOfJoining?.ToString("yyyy-MM-dd")</td>
                <td>
                    <a href="@Url.Action("EditTeacher", "School", new { id = teacher.Id })"
                       class="btn btn-sm btn-primary"
                       title="Edit">
                        <i class="fa fa-edit"></i>
                    </a>
                    <button type="button"
                            class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            data-teacher-id="@teacher.Id"
                            data-teacher-name="@($"{teacher.FirstName} {teacher.LastName}")"
                            title="Delete">
                        <i class="fa fa-trash"></i>
                    </button>
                </td>
            </tr>
            sn++;
        }
        </tbody>
    </table>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
          <div class="modal-header bg-danger text-white">
            <h5 class="modal-title" id="deleteModalLabel">Delete Teacher</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-danger">
            <strong>Are you sure you want to delete <span id="teacherName"></span>?</strong><br />
            This action cannot be undone.
          </div>
          <div class="modal-footer">
            <form id="deleteForm" method="post">
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          </div>
        </div>
      </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Handle delete button click to show modal with correct teacher info
        document.querySelectorAll('button[data-bs-target="#deleteModal"]').forEach(function(btn) {
            btn.addEventListener('click', function () {
                var teacherId = btn.getAttribute('data-teacher-id');
                var teacherName = btn.getAttribute('data-teacher-name');
                document.getElementById('teacherName').textContent = teacherName;
                var form = document.getElementById('deleteForm');
                form.action = '@Url.Action("DeleteTeacher", "School")/' + teacherId;
            });
        });

        // Optional: Auto-hide success popup after 3 seconds
        window.onload = function () {
            var popup = document.getElementById('successPopup');
            if (popup) {
                setTimeout(function () {
                    popup.classList.remove('show');
                }, 3000);
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}