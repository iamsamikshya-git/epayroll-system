@model E_PayRoll.Models.Admin
@{
    ViewBag.Title = "Admin Profile";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

@section Styles{
<style>
  .profile-card{ background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:22px; box-shadow:0 4px 18px rgba(0,0,0,.05); }
  .header{ display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .title{ margin:0; }
  .muted{ color:#6b7280; }
  .avatar{
      width:96px; height:96px; border-radius:14px; object-fit:cover;
      border:1px solid #e5e7eb; background:#f8f9fa;
  }
  .grid{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:14px; }
  .field{ background:#fafafa; border:1px solid #eee; border-radius:10px; padding:12px; }
  .label{ font-size:.85rem; color:#6b7280; margin-bottom:4px; }
  .value{ font-weight:600; word-break:break-word; }
  @@media (max-width: 768px){ .grid{ grid-template-columns:1fr; } }
</style>
}

<div class="container mt-4">
  <!-- Header / actions -->
  <div class="header mb-3">
      <h3 class="title">Admin Profile</h3>
      <div class="d-flex gap-2">
          <a asp-action="EditAdmin" asp-controller="SuperAdmin" asp-route-id="@Model.Id" class="btn btn-primary">
              <i class="bi bi-pencil"></i> Edit
          </a>
          <a href="javascript:history.back()" class="btn btn-secondary">Back</a>
          <button class="btn btn-outline-secondary" onclick="window.print()">
              <i class="bi bi-printer"></i> Print
          </button>
      </div>
  </div>

  <div class="profile-card">
      <!-- Top row: picture + username/email -->
      <div class="d-flex align-items-center gap-3 mb-3">
          @if (!string.IsNullOrEmpty(Model.ProfilePicture))
          {
              <img src="@Url.Content(Model.ProfilePicture)" class="avatar" alt="profile" />
          }
          else
          {
              <div class="avatar d-flex align-items-center justify-content-center">
                  <i class="bi bi-person fs-1 muted"></i>
              </div>
          }
          <div>
              <div class="value">@(Model.User?.Username ?? "—")</div>
              <div class="muted">@Model.Email</div>
          </div>
      </div>

      <!-- Details -->
      <div class="grid">
          <div class="field">
              <div class="label">Country</div>
              <div class="value">@(Model.Country?.Name ?? "—")</div>
          </div>
          <div class="field">
              <div class="label">Province</div>
              <div class="value">@(Model.Province?.Name ?? "—")</div>
          </div>
          <div class="field">
              <div class="label">District</div>
              <div class="value">@(Model.District?.Name ?? "—")</div>
          </div>
          <div class="field">
              <div class="label">Municipality</div>
              <div class="value">@(Model.Municipality?.Name ?? "—")</div>
          </div>
          <div class="field">
              <div class="label">User ID</div>
              <div class="value">@Model.UserId</div>
          </div>
          <div class="field">
              <div class="label">Admin ID</div>
              <div class="value">@Model.Id</div>
          </div>
      </div>
  </div>
</div>

@section Scripts{
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
}
