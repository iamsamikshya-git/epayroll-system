@{
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}


<div class="dashboard-container">
    <h2>SuperAdmin Dashboard</h2>
    <div class="dashboard-links">
        <a href="/SuperAdmin/CreateAdmin" class="dashboard-link">Create Admin</a>
    </div>
</div>

<style>
    .dashboard-container {
        background: #fff;
        max-width: 400px;
        margin: 60px auto;
        padding: 30px 40px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        text-align: center;
    }
    h2 {
        color: #2c3e50;
        margin-bottom: 24px;
    }
    .dashboard-links {
        margin-top: 30px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .dashboard-link {
        display: block;
        background: #007bff;
        color: #fff;
        text-decoration: none;
        padding: 12px 0;
        border-radius: 4px;
        font-size: 18px;
        transition: background 0.2s;
    }
    .dashboard-link:hover {
        background: #0056b3;
    }
</style>