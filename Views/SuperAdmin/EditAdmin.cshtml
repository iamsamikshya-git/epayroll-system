@model E_PayRoll.Models.Admin

@{
    ViewBag.Title = "Edit Admin";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<!-- Font Awesome for icons (optional) -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<h2 class="text-center mt-4">Edit Admin Information</h2>

<div class="container d-flex justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="form-container">
            @using (Html.BeginForm("EditAdmin", "SuperAdmin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)

                <!-- First Row: Location IDs -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.CountryId, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.CountryId, new { @class = "form-control", placeholder = "Country ID", required = "required" })
                        @Html.ValidationMessageFor(m => m.CountryId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.ProvinceId, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.ProvinceId, new { @class = "form-control", placeholder = "Province ID", required = "required" })
                        @Html.ValidationMessageFor(m => m.ProvinceId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.DistrictId, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.DistrictId, new { @class = "form-control", placeholder = "District ID", required = "required" })
                        @Html.ValidationMessageFor(m => m.DistrictId, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Second Row: Municipality ID and Email -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.MunicipalityId, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.MunicipalityId, new { @class = "form-control", placeholder = "Municipality ID", required = "required" })
                        @Html.ValidationMessageFor(m => m.MunicipalityId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email", required = "required", type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Optional: File Upload for Profile Picture -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Profile Picture</label>
                        <input type="file" name="ProfilePictureFile" class="form-control" accept="image/*" />
                    </div>
                </div>

                <!-- Submit & Cancel -->
                <div class="text-center">
                    <button type="submit" class="btn btn-success px-5 me-2">Update</button>
                    <a href="@Url.Action("AdminList", "SuperAdmin")" class="btn btn-secondary px-5">Cancel</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Styling -->
<style>
    .form-container {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        margin-top: 30px;
        margin-bottom: 30px;
    }
</style>
