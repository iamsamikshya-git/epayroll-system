@model E_PayRoll.Models.Admin

@{
    ViewBag.Title = "Edit Admin";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<!-- Font Awesome CDN for eye icon (if needed for password fields) -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<h2 class="text-center mt-4">Edit Admin Information</h2>

<div class="container d-flex justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="form-container">
            @using (Html.BeginForm("EditAdmin", "SuperAdmin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)

                <!-- First Row -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Country, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Country, new { @class = "form-control", placeholder = "Country", required = "required" })
                        @Html.ValidationMessageFor(m => m.Country, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Province, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Province, new { @class = "form-control", placeholder = "Province", required = "required" })
                        @Html.ValidationMessageFor(m => m.Province, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.District, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.District, new { @class = "form-control", placeholder = "District", required = "required" })
                        @Html.ValidationMessageFor(m => m.District, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Second Row -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.LocalBodyType, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.LocalBodyType, new { @class = "form-control", placeholder = "Local Body Type", required = "required" })
                        @Html.ValidationMessageFor(m => m.LocalBodyType, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.LocalBodyName, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.LocalBodyName, new { @class = "form-control", placeholder = "Local Body Name", required = "required" })
                        @Html.ValidationMessageFor(m => m.LocalBodyName, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email", required = "required", type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Logo Row -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Logo</label>
                        <input type="file" name="LogoFile" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(Model.LogoPath))
                        {
                            <div class="mt-2">
                                <img src="@Model.LogoPath" alt="Logo" style="width:60px;height:60px;object-fit:cover;" />
                            </div>
                        }
                    </div>
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-success px-5 me-2">Update</button>
                    <a href="@Url.Action("AdminList", "SuperAdmin")" class="btn btn-secondary px-5">Cancel</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .form-container {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        margin-top: 30px;
        margin-bottom: 30px;
    }
</style>