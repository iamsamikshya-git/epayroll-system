<link rel="stylesheet" href="~/css/site.css" />

<div class="form-container">
    <h2>Create Admin</h2>
    <form method="post">
        <input name="username" placeholder="Username" required />
        <input name="password" type="password" placeholder="Password" required />
        <button type="submit">Create</button>
        <div class="error-message">@ViewBag.Error</div>
        <div class="success-message">@ViewBag.Message</div>
    </form>
</div>

<style>
    .form-container {
        background: #fff;
        max-width: 400px;
        margin: 60px auto;
        padding: 30px 40px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    h2 {
        color: #2c3e50;
        text-align: center;
        margin-bottom: 20px;
    }
    form {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    input {
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 16px;
    }
    button {
        background: #007bff;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
        transition: background 0.2s;
    }
    button:hover {
        background: #0056b3;
    }
    .error-message {
        color: #e74c3c;
        text-align: center;
        margin-top: 10px;
    }
    .success-message {
        color: #27ae60;
        text-align: center;
        margin-top: 10px;
    }
</style>