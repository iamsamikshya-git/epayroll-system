
@model AdminCreateViewModel
@{
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Create Admin - Local Level Registration</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container my-5">
        <div class="card shadow-lg">
            <div class="card-header bg-primary text-white text-center">
                <h4>Create Admin - Local Level Registration</h4>
            </div>
            @if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
{
    <div class="alert alert-danger">@error.ErrorMessage</div>
}

            <div class="card-body">
                <form enctype="multipart/form-data" method="post">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <select id="CountryId" name="CountryId" class="form-select" required>
                                <option value="" selected disabled>Country</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select id="ProvinceId" name="ProvinceId" class="form-select" required>
                                <option value="" selected disabled>Province</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select id="DistrictId" name="DistrictId" class="form-select" required>
                                <option value="" selected disabled>District</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select id="MunicipalityId" name="MunicipalityId" class="form-select" required>
                                <option value="" selected disabled>Municipality</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <input type="text" id="Username" name="Username" class="form-control" placeholder="Username" required />
                        </div>
                        <div class="col-md-4">
                            <input type="email" id="Email" name="Email" class="form-control" placeholder="Email Address" required />
                        </div>
                        <div class="col-md-4">
                            <input type="file" id="ProfilePicture" name="ProfilePicture" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <input type="password" id="Password" name="Password" class="form-control" placeholder="Password" required />
                        </div>
                        <div class="col-md-6">
                            <input type="password" id="ConfirmPassword" name="ConfirmPassword" class="form-control" placeholder="Confirm Password" required />
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-success px-4">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<!-- jQuery (required for AJAX and DOM manipulation) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    $(document).ready(function () {
        $.getJSON('/SuperAdmin/GetCountries', function (data) {
            $('#CountryId').append(data.map(c => `<option value="${c.id}">${c.name}</option>`));
        });

        $('#CountryId').change(function () {
            const countryId = $(this).val();
            $('#ProvinceId').empty().append('<option selected disabled>Select Province</option>');
            $('#DistrictId, #MunicipalityId').empty().append('<option selected disabled>Select</option>');

            $.getJSON(`/SuperAdmin/GetProvinces?countryId=${countryId}`, function (data) {
                $('#ProvinceId').append(data.map(p => `<option value="${p.id}">${p.name}</option>`));
            });
        });

        $('#ProvinceId').change(function () {
            const provinceId = $(this).val();
            $('#DistrictId').empty().append('<option selected disabled>Select District</option>');
            $('#MunicipalityId').empty().append('<option selected disabled>Select Municipality</option>');

            $.getJSON(`/SuperAdmin/GetDistricts?provinceId=${provinceId}`, function (data) {
                $('#DistrictId').append(data.map(d => `<option value="${d.id}">${d.name}</option>`));
            });
        });

        $('#DistrictId').change(function () {
            const districtId = $(this).val();
            $('#MunicipalityId').empty().append('<option selected disabled>Select Municipality</option>');

            $.getJSON(`/SuperAdmin/GetMunicipalities?districtId=${districtId}`, function (data) {
                $('#MunicipalityId').append(data.map(m => `<option value="${m.id}">${m.name}</option>`));
            });
        });
    });
</script>

</body>
</html>
