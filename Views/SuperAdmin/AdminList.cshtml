@model IEnumerable<E_PayRoll.ViewModels.AdminListViewModel>

@{
    ViewBag.Title = "Admin List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<h2 class="text-center mt-4 mb-4">Admin List</h2>

<style>
    th.action-col, td.action-col {
        min-width: 120px;
        text-align: center;
    }
</style>

<div class="container d-flex justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="table-container">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert" id="successPopup">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>S.N.</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Country</th>
                        <th>Province</th>
                        <th>District</th>
                        <th>Local Body Name</th>
                        <th>Local Body Type</th>
                        <th>Logo</th>
                        <th class="action-col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int sn = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@sn</td>
                                <td>@item.User?.Username</td>
                                <td>@item.Admin?.Email</td>
                                <td>@item.Admin?.Country</td>
                                <td>@item.Admin?.Province</td>
                                <td>@item.Admin?.District</td>
                                <td>@item.Admin?.LocalBodyName</td>
                                <td>@item.Admin?.LocalBodyType</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Admin?.LogoPath))
                                    {
                                        <img src="@item.Admin.LogoPath" alt="Logo" style="width:40px;height:40px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td class="action-col">
                                    <a href="@Url.Action("EditAdmin", "SuperAdmin", new { id = item.Admin?.Id })" class="btn btn-sm btn-primary me-1" title="Edit">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-admin-id="@item.Admin?.Id"
                                            data-admin-name="@item.User?.Username"
                                            title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            sn++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center">No admins found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-danger">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="deleteModalLabel">Delete Admin</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-danger">
        <strong>Are you sure you want to delete <span id="adminName"></span>? This cannot be undone.</strong>
      </div>
      <div class="modal-footer">
        <form id="deleteForm" method="post">
            @Html.AntiForgeryToken()
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Handle delete button click to show modal with correct admin info
        document.querySelectorAll('button[data-bs-target="#deleteModal"]').forEach(function(btn) {
            btn.addEventListener('click', function () {
                var adminId = btn.getAttribute('data-admin-id');
                var adminName = btn.getAttribute('data-admin-name');
                document.getElementById('adminName').textContent = adminName;
                var form = document.getElementById('deleteForm');
                form.action = '@Url.Action("DeleteAdmin", "SuperAdmin")/' + adminId;
            });
        });

        // Auto-hide success popup after 3 seconds
        window.onload = function () {
            var popup = document.getElementById('successPopup');
            if (popup) {
                setTimeout(function () {
                    popup.classList.remove('show');
                }, 3000);
            }
        }
    </script>
}