@model IEnumerable<E_PayRoll.ViewModels.AdminListViewModel>

@{
    ViewBag.Title = "Admin List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<h2 class="text-center mt-4 mb-4">Admin List</h2>

<div class="container d-flex justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="table-container">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>S.N.</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Country</th>
                        <th>Province</th>
                        <th>District</th>
                        <th>Local Body Name</th>
                        <th>Local Body Type</th>
                        <th>Logo</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int sn = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@sn</td>
                                <td>@item.User?.Username</td>
                                <td>@item.Admin?.Email</td>
                                <td>@item.Admin?.Country</td>
                                <td>@item.Admin?.Province</td>
                                <td>@item.Admin?.District</td>
                                <td>@item.Admin?.LocalBodyName</td>
                                <td>@item.Admin?.LocalBodyType</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Admin?.LogoPath))
                                    {
                                        <img src="@item.Admin.LogoPath" alt="Logo" style="width:40px;height:40px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                            sn++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center">No admins found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>