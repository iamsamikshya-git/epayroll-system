@model IEnumerable<E_PayRoll.Models.User>

@{
    ViewBag.Title = "Admin List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin List</title>

    <!-- Bootstrap CSS (optional if already included in your layout) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        h2 {
            margin-top: 30px;
            margin-bottom: 30px;
        }

        .table-container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center">
        <div class="col-md-10 col-lg-8">
            <h2 class="text-center">Admin List</h2>

            <div class="table-container">
                <table class="table table-bordered table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>S.N.</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Country</th>
                            <th>Province</th>
                            <th>District</th>
                            <th>Local Body Name</th>
                            <th>Local Body Type</th>
                            <th>Logo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int sn = 1;
                            foreach (var admin in Model)
                            {
                                <tr>
                                    <td>@sn</td>
                                    <td>@admin.Username</td>
                                    <td>@admin.Email</td>
                                    <td>@admin.Country</td>
                                    <td>@admin.Province</td>
                                    <td>@admin.District</td>
                                    <td>@admin.LocalBodyName</td>
                                    <td>@admin.LocalBodyType</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(admin.LogoPath))
                                        {
                                            <img src="@admin.LogoPath" alt="Logo" style="width:40px;height:40px;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                </tr>
                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center">No admins found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>
