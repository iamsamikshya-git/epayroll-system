<link rel="stylesheet" href="~/css/site.css" />
<!-- Font Awesome for eye icon -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
<link rel="stylesheet" href="~/css/site.css" />

<div class="auth-wrap">
  <div class="auth-card">
    <!-- LEFT: gradient panel with BIG logo -->
    <div class="auth-left">
      <img src="@Url.Content("~/AdminCast/Images/nepalsarkarlogo.png")" class="crest-lg" alt="Emblem" />
    </div>

    <!-- RIGHT: header + your EXISTING form (unchanged fields & JS) -->
    <div class="auth-right">
      <div class="text-center auth-brand">
        <img src="@Url.Content("~/AdminCast/Images/nepalsarkarlogo.png")" class="crest-sm" alt="Emblem" />
        <div class="app-title">School Payroll Reporting System</div>
      </div>

      <h2 class="sr-only">Login</h2>
      <form method="post">
        <input name="username" placeholder="Email Or School Code" required />

        <div class="password-wrapper">
          <input id="password" name="password" type="password" placeholder="Password" required />
          <button type="button" class="eye-toggle-btn"
                  onclick="togglePassword('password', this.querySelector('i'))"
                  aria-label="Toggle password visibility" title="Show/Hide Password">
            <i class="fa-solid fa-eye-slash"></i>
          </button>
        </div>

        <button type="submit">Login</button>
        <div class="error-message">@ViewBag.Error</div>
      </form>
    </div>
  </div>
</div>


<style>
    body {
        background: #f8f9fa;
        font-family: Arial, sans-serif;
    }

    .login-container {
        background: #fff;
        padding: 32px 40px;
        margin: 80px auto;
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.10);
        max-width: 350px;
    }

    h2 {
        color: #2c3e50;
        text-align: center;
        margin-bottom: 24px;
    }

    form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    input {
        width: 100%;
        padding: 12px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 16px;
        transition: border 0.2s;
    }

    input:focus {
        border-color: #007bff;
        box-shadow: 0 0 4px rgba(0, 123, 255, 0.25);
        outline: none;
    }

    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .password-wrapper input {
        padding-right: 42px;
    }

    .eye-toggle-btn {
        position: absolute;
        right: 6px;
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 18px;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c757d;
        transition: color 0.2s, background 0.2s;
    }

    .eye-toggle-btn:hover {
        background: rgba(0, 0, 0, 0.05);
        color: #343a40;
    }

    button[type="submit"] {
        width: 100%;
        background: #007bff;
        color: #fff;
        border: none;
        padding: 12px;
        border-radius: 4px;
        font-size: 17px;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 8px;
    }

    button[type="submit"]:hover {
        background: #0056b3;
    }

    .error-message {
        color: #e74c3c;
        text-align: center;
        margin-top: 10px;
    }
</style>
<style>
/* Split layout shell */
.auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
.auth-card { width:100%; max-width:1100px; background:#fff; border-radius:18px; overflow:hidden;
             box-shadow:0 12px 30px rgba(0,0,0,.08); display:grid; grid-template-columns:1fr 1fr; }

/* Left gradient panel */
.auth-left { background:linear-gradient(135deg,#6a11cb 0%,#2575fc 100%); display:grid; place-items:center; min-height:440px; }

/* Right form panel */
.auth-right { padding:40px 36px; }
.auth-brand { margin-bottom:18px; }
.app-title { font-weight:700; font-size:1.25rem; margin-top:.6rem; }

/* Same image file, different sizes */
.crest-lg { width:240px; height:auto; filter:drop-shadow(0 8px 24px rgba(0,0,0,.25)); }
.crest-sm { width:64px;  height:auto; }

/* Responsive: stack on small screens */

</style>


<script>
    function togglePassword(id, icon) {
        const input = document.getElementById(id);
        const isPassword = input.type === "password";

        input.type = isPassword ? "text" : "password";
        icon.classList.toggle("fa-eye");
        icon.classList.toggle("fa-eye-slash");
    }
</script>
