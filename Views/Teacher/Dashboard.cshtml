@{
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<div class="dashboard-container">
    @* <h2>Teacher Dashboard</h2> *@
    <div class="card teacher-card">
        <div class="card-body">
            <h4 class="card-title mb-3">Welcome, @Model.FirstName @Model.LastName</h4>
            <p class="card-text"><strong>Department:</strong> @Model.Department</p>
            <p class="card-text"><strong>Designation:</strong> @Model.Designation</p>
            <p class="card-text"><strong>School:</strong> @Model.School?.SchoolName</p>
        </div>
    </div>
    @* You can add dashboard stats or welcome message here *@
</div>

<style>
    .dashboard-container {
        background: #fff;
        max-width: 400px;
        margin: 60px auto;
        padding: 30px 40px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        text-align: center;
    }
    .teacher-card {
        border: 1px solid #e3e3e3;
        border-radius: 8px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
        margin-bottom: 20px;
        background: #f9f9f9;
    }
    .teacher-card .card-body {
        padding: 20px;
    }
    .card-title {
        color: #2c3e50;
        font-weight: 600;
    }
    .card-text {
        margin-bottom: 10px;
        color: #444;
    }
</style>