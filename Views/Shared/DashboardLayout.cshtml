@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@{
    
    ViewBag.Title = "Dashboard";

    var isAdmin = User != null && User.IsInRole("Admin");
    var isSuperAdmin = User != null && User.IsInRole("SuperAdmin");
    var userName = User?.Identity?.Name ?? "User";
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - AdminCAST</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    #wrapper {
        display: flex;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .sidebar {
        width: 250px;
        background-color: #263544;
        color: white;
        height: 100vh;
        padding-top: 20px;
        transition: margin-left 0.3s ease;
        position: fixed;
        z-index: 1000;
    }

    .sidebar.collapsed {
        margin-left: -250px;
    }

    .sidebar .user-panel {
        text-align: center;
        padding: 10px;
    }

    .sidebar .user-panel img {
        width: 60px;
        border-radius: 50%;
    }

    .sidebar .nav-link {
        color: #cfd8dc;
        padding: 10px 20px;
    }

    .sidebar .nav-link:hover {
        background-color: #34495e;
        color: white;
    }

    .main-content {
        margin-left: 250px;
        transition: margin-left 0.3s ease;
        width: 100%;
        padding: 0;
    }

    .main-content.expanded {
        margin-left: 0;
    }

    .topbar {
        height: 60px;
        background: #fff;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #ddd;
    }

    .topbar input {
        width: 300px;
        border-radius: 20px;
        border: 1px solid #ccc;
        padding: 5px 15px;
    }

    .dropdown-menu {
        right: 0;
        left: auto;
    }

    /* Responsive Sidebar Handling */
     @@media (max-width: 768px) {
        .sidebar {
            margin-left: -250px;
        }

        .sidebar.show {
            margin-left: 0;
        }

        .main-content {
            margin-left: 0;
        }
    }
</style>

</head>

<body>
    
@if (User != null && User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
{
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="text-center fs-4 fw-bold mb-3">Dash</div>
            <div class="user-panel mb-3">
                <img src="~/AdminCast/Images/admin-avatar.png" width="45px" />
                <div><small>@(isAdmin ? "Administrator" : isSuperAdmin ? "Super Administrator" : "User")</small></div>
            </div>
            <ul class="nav flex-column">
                @if (isAdmin)
                {
                    <li><a href="@Url.Action("Dashboard", "Admin")" class="nav-link"><i class="fas fa-th-large me-2"></i>Dashboard</a></li>
                    <li><a href="@Url.Action("SchoolList", "Admin")" class="nav-link"><i class="fas fa-school me-2"></i>View Schools</a></li>
                    <li><a href="@Url.Action("CreateSchool", "Admin")" class="nav-link"><i class="fas fa-plus me-2"></i>Create School</a></li>
                }
                @if (isSuperAdmin)
                {
                    <li><a href="@Url.Action("Dashboard", "SuperAdmin")" class="nav-link"><i class="fas fa-th-large me-2"></i>Dashboard</a></li>
                    <li><a href="@Url.Action("CreateAdmin", "SuperAdmin")" class="nav-link"><i class="fas fa-user-plus me-2"></i>Create Admin</a></li>
                    <li><a href="@Url.Action("AdminList", "SuperAdmin")" class="nav-link"><i class="fas fa-user-plus me-2"></i>Admin List</a></li>
                }
                @if (isAdmin)
                {
                    <li class="mt-2 ps-3 text-uppercase small">Admin</li>
                    <li><a href="#" class="nav-link"><i class="fas fa-user-cog me-2"></i> Manage Users</a></li>
                }
                @if (isSuperAdmin)
                {
                    <li class="mt-2 ps-3 text-uppercase small">SuperAdmin</li>
                    <li><a href="#" class="nav-link"><i class="fas fa-tools me-2"></i> Global Settings</a></li>
                }
            </ul>
        </div>
    
        <!-- Main Content -->
        <div class="main-content flex-grow-1" id="mainContent">
            <!-- Topbar -->
            <div class="topbar d-flex align-items-center justify-content-between">
                <button class="btn btn-outline-light d-md-none ms-2" id="toggleSidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <input type="text" class="form-control mx-3" placeholder="Search here..." style="max-width: 300px;" />
                <div class="d-flex align-items-center">
                    <i class="fas fa-envelope me-3 position-relative">
                        <span class="badge bg-primary position-absolute top-0 start-100 translate-middle">9</span>
                    </i>
                    <i class="fas fa-bell me-3"></i>
                    <div class="dropdown">
                        <a class="dropdown-toggle d-flex align-items-center text-dark text-decoration-none" href="#"
                           id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="~/AdminCast/Images/admin-avatar.png" class="rounded-circle me-2" />
                            @userName
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Account")"><i class="fas fa-user me-2"></i> Profile</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Settings", "Account")"><i class="fas fa-cog me-2"></i> Settings</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Support", "Account")"><i class="fas fa-question-circle me-2"></i> Support</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-power-off me-2"></i> Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- Page Content -->
           <div class="container-fluid mt-4">
                @RenderBody()
                </div>
            
        </div>

    </div>
    
    
}

 
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById("toggleSidebar").addEventListener("click", function () {
        document.getElementById("sidebar").classList.toggle("collapsed");
        document.getElementById("mainContent").classList.toggle("expanded");
    });
</script>
</body>

</html>