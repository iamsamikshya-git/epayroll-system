@model IEnumerable<E_PayRoll.Models.School>
<link rel="stylesheet" href="~/css/site.css" />

<div class="school-list-container">
    <h2>School List</h2>
    <a href="/Admin/CreateSchool" class="create-school-link">Create New School</a>
    <table class="school-table">
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Action</th>
        </tr>
        @foreach(var school in Model)
        {
            <tr>
                <td>@school.Name</td>
                <td>@school.Address</td>
                <td>
                    <form asp-action="DeleteSchool" method="post" style="display:inline">
                        <input type="hidden" name="id" value="@school.Id" />
                        <button type="submit" class="delete-btn">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </table>
</div>

<style>
    .school-list-container {
        background: #fff;
        max-width: 700px;
        margin: 60px auto;
        padding: 30px 40px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    h2 {
        color: #2c3e50;
        text-align: center;
    }
    .create-school-link {
        display: inline-block;
        margin-bottom: 20px;
        background: #28a745;
        color: #fff;
        padding: 8px 16px;
        border-radius: 4px;
        text-decoration: none;
        transition: background 0.2s;
    }
    .create-school-link:hover {
        background: #218838;
    }
    .school-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }
    .school-table th, .school-table td {
        border: 1px solid #ddd;
        padding: 12px;
        text-align: center;
    }
    .school-table th {
        background: #007bff;
        color: #fff;
    }
    .school-table tr:nth-child(even) {
        background: #f2f2f2;
    }
    .delete-btn {
        background: #dc3545;
        color: #fff;
        border: none;
        padding: 6px 14px;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .delete-btn:hover {
        background: #b52a37;
    }
</style>