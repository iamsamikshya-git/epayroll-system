@model IEnumerable<E_PayRoll.ViewModels.SchoolListViewModel>

@{
    ViewBag.Title = "School List";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<h2 class="text-center mt-4 mb-4">School List</h2>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<div class="container d-flex justify-content-center">
    <div class="col-md-10 col-lg-8">

        @* Success and Error message popups *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" id="successPopup">
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorPopup">
                <strong>Error!</strong> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="mb-3 text-end">
            <a asp-controller="Admin" asp-action="CreateSchool" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Create New School
            </a>
        </div>

        <div class="input-group mb-3" style="max-width: 300px;">
            <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Search schools..." />
            <button class="btn btn-outline-secondary btn-sm" type="button" id="searchButton" style="width: 40px;">
                <i class="bi bi-search"></i>
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>S.N.</th>
                        <th>School Name</th>
                        <th>Tole</th>
                        <th>Telephone No</th>
                        <th>Email</th>
                        <th style="min-width:120px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int sn = 1;
                        foreach (var school in Model)
                        {
                            <tr>
                                <td>@sn</td>
                                <td>@school.School?.SchoolName</td>
                                <td>@school.School?.Tole</td>
                                <td>@school.School?.TelephoneNo</td>
                                <td>@school.School?.Email</td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="EditSchool" asp-controller="Admin" asp-route-id="@school.School?.Id" class="btn btn-sm btn-primary"  title="Edit">
                                            <i class="fas fa-pen"></i> 
                                        </a>
                                        <button type="button" class="btn btn-outline-danger delete-btn"
                                            data-id="@school.School?.Id" title="Delete" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                            <i class="bi bi-trash-fill fs-5"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            sn++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No schools found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this school? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" asp-controller="Admin" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteSchoolId" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(function () {
            // Search functionality
            $("#searchButton").on("click", function () {
                var searchText = $("#searchInput").val().toLowerCase();
                $("tbody tr").each(function () {
                    var rowText = $(this).text().toLowerCase();
                    $(this).toggle(rowText.indexOf(searchText) !== -1);
                });
            });

            // Real-time search on input keyup
            $("#searchInput").on("keyup", function () {
                $("#searchButton").click();
            });

            // Handle delete button click
            $(".delete-btn").on("click", function () {
                var id = $(this).data("id");
                $("#deleteSchoolId").val(id);
            });

            // Auto close success and error alerts after 3 seconds
            setTimeout(function () {
                $("#successPopup").alert('close');
                $("#errorPopup").alert('close');
            }, 3000);
        });
    </script>
    <script src="https://kit.fontawesome.com/2c36e9b7b1.js" crossorigin="anonymous"></script>
}