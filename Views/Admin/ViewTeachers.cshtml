@model IEnumerable<E_PayRoll.Models.Teacher>

@{
    ViewBag.Title = "Teachers of " + (ViewBag.SchoolName ?? "School");
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

@section Styles {
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />

    <style>
        #teacherBlock { padding-left: 0 !important; }
        #teacherBlock .dataTables_wrapper,
        #teacherBlock .dt-card,
        #teacherBlock table { margin-left: 0 !important; }

        .table thead th { background-color: #007bff; color: #fff; text-align: center; }
        .table td, .table th { vertical-align: middle; }

        #teacherTable_wrapper .dt-card { border:1px solid #dee2e6; border-radius:.5rem; background:#fff; overflow:hidden; }
        #teacherTable_wrapper .dt-head,
        #teacherTable_wrapper .dt-foot { padding:.75rem 1rem; background:#fff; display:flex; justify-content:space-between; align-items:center; gap:.5rem; flex-wrap:wrap; }
        #teacherTable_wrapper .dt-head { border-bottom:1px solid #dee2e6; }
        #teacherTable_wrapper .dt-foot { border-top:1px solid #dee2e6; }

        #teacherTable_wrapper .dataTables_length select,
        #teacherTable_wrapper .dataTables_filter input {
            border:1px solid #ced4da; border-radius:.375rem; padding:.375rem .75rem; height:calc(1.5em + .75rem + 2px);
        }

        #teacherTable { margin:0 !important; width:100%; }
    </style>
}

<div id="teacherBlock" class="container-fluid mt-4">
    <h2 class="text-center mb-4">Teachers of @ViewBag.SchoolName</h2>

    <table id="teacherTable" class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>S.N</th>
                <th>Full Name</th>
                <th>Date of Birth</th>
                <th>Gender</th>
                <th>Email</th>
                <th>National ID</th>
            </tr>
        </thead>
        <tbody>
            @{
                var sn = 1;
            }
            @if (Model != null && Model.Any())
            {
                foreach (var teacher in Model)
                {
                    <tr>
                        <td>@sn</td>
                        <td>@($"{teacher.FirstName} {teacher.MiddleName} {teacher.LastName}")</td>
                        <td>@teacher.DateOfBirth.ToString("yyyy-MM-dd")</td>
                        <td>@teacher.Gender</td>
                        <td>@teacher.Email</td>
                        <td>@teacher.NationalId</td>
                    </tr>
                    sn++;
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No teachers found.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-action="TeachersBySchool" asp-controller="Admin" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Schools
        </a>
    </div>
</div>

@section Scripts {
    <!-- jQuery + DataTables -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>

    <script>
        $(function () {
            const dt = $('#teacherTable').DataTable({
                dom: '<"dt-card"<"dt-head d-flex justify-content-between align-items-center flex-wrap gap-2"l f>t<"dt-foot d-flex justify-content-between align-items-center flex-wrap gap-2"i p>>',
                pageLength: 10,
                language: {
                    lengthMenu: "Show _MENU_ entries",
                    zeroRecords: "No matching records found",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty: "No entries available",
                    search: "Search:"
                }
            });

            $(window).on('resize', function(){ dt.columns.adjust(); });
        });
    </script>
}
