@model E_PayRoll.ViewModels.SchoolListViewModel

@{
    ViewData["Title"] = "Edit School";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<h2 class="mb-4">Edit School</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container-fluid px-4" style="max-width: 700px; margin: auto;">
    <form asp-action="EditSchool" method="post" novalidate class="d-flex flex-column align-items-end">
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.School.Id)
        @Html.HiddenFor(m => m.User.Id)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <!-- School Info -->
        <div id="basicInfoSection" class="w-100">
            <div class="row g-3 mb-3 justify-content-end">
                <div class="col-md-4">
                    <label class="form-label" for="School_SchoolName">School Name</label>
                    <input asp-for="School.SchoolName" class="form-control" />
                    <span asp-validation-for="School.SchoolName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="School_Tole">Tole</label>
                    <input asp-for="School.Tole" class="form-control" />
                    <span asp-validation-for="School.Tole" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="School_TelephoneNo">Telephone No</label>
                    <input asp-for="School.TelephoneNo" class="form-control" />
                    <span asp-validation-for="School.TelephoneNo" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label" for="School_WardNo">Ward No</label>
                    <input asp-for="School.WardNo" class="form-control" />
                    <span asp-validation-for="School.WardNo" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="School_AccountNo">Account No</label>
                    <input asp-for="School.AccountNo" class="form-control" />
                    <span asp-validation-for="School.AccountNo" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="School_ContactPerson">Contact Person</label>
                    <input asp-for="School.ContactPerson" class="form-control" />
                    <span asp-validation-for="School.ContactPerson" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-4 text-end">
                <button id="showAdminDetailBtn" type="button" class="btn btn-info">Edit Admin Info</button>
            </div>
        </div>

        <!-- Admin Section -->
        <div id="adminDetailSection" class="w-100" style="display:none;">
            <div class="row g-3 mb-3 justify-content-end">
                <div class="col-md-4">
                    <label class="form-label" for="School_Email">Email</label>
                    <input asp-for="School.Email" class="form-control" />
                    <span asp-validation-for="School.Email" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="School_UserPerson">User Person</label>
                    <input asp-for="School.UserPerson" class="form-control" />
                    <span asp-validation-for="School.UserPerson" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="School_EMISCode">EMIS Code</label>
                    <input asp-for="School.EMISCode" class="form-control" />
                    <span asp-validation-for="School.EMISCode" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label" for="User_Username">Username</label>
                    <input asp-for="User.Username" class="form-control" />
                    <span asp-validation-for="User.Username" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label" for="User_Password">Password</label>
                    <div class="input-group">
                        <input asp-for="User.Password" type="password" class="form-control" id="password" />
                        <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePassword('password')">👁</button>
                    </div>
                    <span asp-validation-for="User.Password" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="text-end mb-5">
            <button type="submit" class="btn btn-success px-5">Update</button>
            <a asp-action="SchoolList" class="btn btn-secondary ms-2">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('showAdminDetailBtn').addEventListener('click', function () {
            document.getElementById('adminDetailSection').style.display = 'block';
            this.style.display = 'none';
        });

        function togglePassword(id) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
}
