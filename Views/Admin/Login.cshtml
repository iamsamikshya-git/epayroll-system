<style>
    body {
        background: #f8f9fa;
        font-family: Arial, sans-serif;
    }
    .login-container {
        background: #fff;
        padding: 30px 40px;
        margin: 60px auto;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        max-width: 350px;
    }
    h2 {
        color: #2c3e50;
        text-align: center;
    }
    input {
        width: 100%;
        margin: 10px 0;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }
    button {
        width: 100%;
        background: #007bff;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
    }
    button:hover {
        background: #0056b3;
    }
    .error-message {
        color: #e74c3c;
        text-align: center;
        margin-top: 10px;
    }
</style>

<div class="login-container">
    <h2>Admin Login</h2>
    <form method="post">
        <input name="username" placeholder="Username" required />
        <input name="password" type="password" placeholder="Password" required />
        <button type="submit">Login</button>
        <div class="error-message">@ViewBag.Error</div>
    </form>
</div>