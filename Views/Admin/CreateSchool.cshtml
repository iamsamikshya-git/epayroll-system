@model E_PayRoll.ViewModels.SchoolListViewModel

@{
    ViewData["Title"] = "Create School";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

<h2 class="mb-4">Create School</h2>

@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<div class="container-fluid px-4" style="max-width: 700px; margin: auto;">
    <form asp-action="CreateSchool" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="School.SchoolName" class="form-label"></label>
                <input asp-for="School.SchoolName" class="form-control" />
                <span asp-validation-for="School.SchoolName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="School.Tole" class="form-label"></label>
                <input asp-for="School.Tole" class="form-control" />
                <span asp-validation-for="School.Tole" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="School.TelephoneNo" class="form-label"></label>
                <input asp-for="School.TelephoneNo" class="form-control" />
                <span asp-validation-for="School.TelephoneNo" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="School.WardNo" class="form-label"></label>
                <input asp-for="School.WardNo" class="form-control" />
                <span asp-validation-for="School.WardNo" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="School.AccountNo" class="form-label"></label>
                <input asp-for="School.AccountNo" class="form-control" />
                <span asp-validation-for="School.AccountNo" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="School.ContactPerson" class="form-label"></label>
                <input asp-for="School.ContactPerson" class="form-control" />
                <span asp-validation-for="School.ContactPerson" class="text-danger"></span>
            </div>
        </div>

        <button type="button" class="btn btn-outline-primary mb-3" id="toggleAdminFieldsBtn">
            Add Administer Detail
        </button>

        <div id="adminFields" style="display:none;">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="School.EMISCode" class="form-label"></label>
                    <input asp-for="School.EMISCode" class="form-control" />
                    <span asp-validation-for="School.EMISCode" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="School.UserPerson" class="form-label"></label>
                    <input asp-for="School.UserPerson" class="form-control" />
                    <span asp-validation-for="School.UserPerson" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="School.Email" class="form-label"></label>
                    <input asp-for="School.Email" class="form-control" />
                    <span asp-validation-for="School.Email" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" id="Password" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('Password')">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="ConfirmPassword" autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('ConfirmPassword')">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <input asp-for="User.Role" type="hidden" value="School" />
            </div>
        </div>

        <div class="text-end mb-5">
            <button type="submit" class="btn btn-success px-5">Submit</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <script>
        // Password toggler
        function togglePassword(id) {
            var input = document.getElementById(id);
            if (input) {
                input.type = input.type === "password" ? "text" : "password";
            }
        }

        // Show/hide admin fields (including EMISCode)
        $("#toggleAdminFieldsBtn").on("click", function () {
            $("#adminFields").slideToggle();
        });
    </script>
}