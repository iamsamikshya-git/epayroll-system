@model E_PayRoll.Models.School
@{
    ViewBag.Title = "School Profile";
    Layout = "~/Views/Shared/DashboardLayout.cshtml";
}

@section Styles{
<style>
  .profile-card{ background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:22px; box-shadow:0 4px 18px rgba(0,0,0,.05); }
  .header{ display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .title{ margin:0; }
  .muted{ color:#6b7280; }
  .grid{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:14px; }
  .field{ background:#fafafa; border:1px solid #eee; border-radius:10px; padding:12px; }
  .label{ font-size:.85rem; color:#6b7280; margin-bottom:4px; }
  .value{ font-weight:600; word-break:break-word; }
  @@media (max-width: 768px){ .grid{ grid-template-columns:1fr; } }
</style>
}

<div class="container mt-4">
  <div class="header mb-3">
      <h3 class="title">School Profile</h3>
      <div class="d-flex gap-2">
          <a asp-action="EditSchool" asp-controller="Admin" asp-route-id="@Model.Id" class="btn btn-primary">
              <i class="bi bi-pencil"></i> Edit
          </a>
          <a href="javascript:history.back()" class="btn btn-secondary">Back</a>
          <button class="btn btn-outline-secondary" onclick="window.print()">
              <i class="bi bi-printer"></i> Print
          </button>
      </div>
  </div>

  <div class="profile-card">
      <div class="mb-3">
          <h4 class="mb-1">@Model.SchoolName</h4>
          <div class="muted">EMIS Code: @Model.EMISCode</div>
      </div>

      <div class="grid">
          <div class="field">
              <div class="label">Tole</div>
              <div class="value">@Model.Tole</div>
          </div>
          <div class="field">
              <div class="label">Telephone No</div>
              <div class="value">@Model.TelephoneNo</div>
          </div>
          <div class="field">
              <div class="label">Ward No</div>
              <div class="value">@Model.WardNo</div>
          </div>
          <div class="field">
              <div class="label">Account No</div>
              <div class="value">@Model.AccountNo</div>
          </div>
          <div class="field">
              <div class="label">Contact Person</div>
              <div class="value">@Model.ContactPerson</div>
          </div>
          <div class="field">
              <div class="label">Email</div>
              <div class="value">@Model.Email</div>
          </div>
          <div class="field">
              <div class="label">User Person</div>
              <div class="value">@Model.UserPerson</div>
          </div>
          @* <div class="field">
              <div class="label">Admin (optional)</div>
              <div class="value">@Model.Admin?.User ?? "—"</div>
          </div>
          <div class="field">
              <div class="label">Linked User (optional)</div>
              <div class="value">@Model.User?.Username ?? "—"</div>
          </div> *@
      </div>
  </div>
</div>

@section Scripts{
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
}
